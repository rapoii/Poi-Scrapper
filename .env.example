# ============================================================================
# PoiScrapper v3 — Environment Variables (template)
# Copy ke `.env` dan isi sesuai environment lokal / deployment.
# JANGAN PERNAH isi secret asli di file ini — `.env.example` masuk git.
# ============================================================================

# ---------- General ----------
APP_ENV=development            # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
TZ=Asia/Jakarta

# ---------- Backend (FastAPI) ----------
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_CORS_ORIGINS=http://localhost:3000

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# ---------- Database (Postgres) ----------
POSTGRES_USER=poiscrapper
POSTGRES_PASSWORD=poiscrapper_dev
POSTGRES_DB=poiscrapper
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://poiscrapper:poiscrapper_dev@localhost:5432/poiscrapper
DATABASE_URL_SYNC=postgresql+psycopg://poiscrapper:poiscrapper_dev@localhost:5432/poiscrapper

# ---------- Redis (broker + pub/sub) ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- LLM (Gemini default, free tier) ----------
LLM_PROVIDER=gemini            # gemini | groq | openrouter | openai | anthropic
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- Auth (Phase 2, Supabase) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---------- Storage (Phase 3, Cloudflare R2 S3-compatible) ----------
STORAGE_PROVIDER=local         # local | r2 | supabase
STORAGE_LOCAL_PATH=./storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=poiscrapper
R2_PUBLIC_URL=

# ---------- Scraping ----------
SCRAPER_DEFAULT_TIMEOUT_MS=30000
SCRAPER_MAX_CONCURRENCY=3
SCRAPER_USER_AGENTS_FILE=./apps/api/app/assets/user_agents.txt
RESPECT_ROBOTS_TXT=true

# ---------- Proxy (optional, Phase 3) ----------
PROXY_PROVIDER=                # brightdata | smartproxy | custom
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ---------- Notifications (Phase 2) ----------
RESEND_API_KEY=
EMAIL_FROM=notifications@poiscrapper.local

# ---------- Observability (Phase 3) ----------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
